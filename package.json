{
  "name": "@umituz/web-ai-content",
  "version": "2.0.1",
  "description": "Comprehensive AI content generation suite with text, image, video, and wizard flow orchestration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "import": "./dist/domain/index.mjs",
      "require": "./dist/domain/index.js"
    },
    "./application": {
      "types": "./dist/application/index.d.ts",
      "import": "./dist/application/index.mjs",
      "require": "./dist/application/index.js"
    },
    "./presentation": {
      "types": "./dist/presentation/index.d.ts",
      "import": "./dist/presentation/index.mjs",
      "require": "./dist/presentation/index.js"
    },
    "./providers": {
      "types": "./dist/infrastructure/providers/index.d.ts",
      "import": "./dist/infrastructure/providers/index.mjs",
      "require": "./dist/infrastructure/providers/index.js"
    },
    "./wizard": {
      "types": "./dist/application/flows/index.d.ts",
      "import": "./dist/application/flows/index.mjs",
      "require": "./dist/application/flows/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/domain/index.ts src/application/index.ts src/presentation/index.ts src/infrastructure/providers/index.ts src/application/flows/index.ts --format cjs,esm --dts --clean --external react",
    "dev": "tsup src/index.ts src/domain/index.ts src/application/index.ts src/presentation/index.ts src/infrastructure/providers/index.ts src/application/flows/index.ts --format cjs,esm --dts --watch --external react",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "content-generation",
    "text-to-image",
    "text-to-video",
    "image-to-video",
    "wizard-flow",
    "multi-provider",
    "groq",
    "fal",
    "pruna",
    "gemini",
    "seo",
    "social-media",
    "blog",
    "video-script",
    "typescript",
    "react"
  ],
  "author": "umituz",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  }
}
